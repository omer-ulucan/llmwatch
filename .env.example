# ── AWS ─────────────────────────────────────────────────
# Use IAM roles in production — env vars for local dev only
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
DYNAMODB_TABLE_LOGS=llmwatch_logs
DYNAMODB_TABLE_USERS=llmwatch_users

# ── Authentication ───────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_32_char_minimum_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# ── LLM Models ───────────────────────────────────────────
GOOGLE_API_KEY=your_gemini_api_key_here
QWEN_BASE_URL=http://localhost:8001/v1
QWEN_API_KEY=llmwatch-internal-key

# ── MLFlow ───────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Application ──────────────────────────────────────────
APP_ENV=development
APP_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000
